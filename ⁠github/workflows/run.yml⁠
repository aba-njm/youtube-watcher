name: YouTube Auto Archiver Bot

on:
  schedule:
    - cron: '*/15 * * * *' # تشغيل تلقائي كل 15 دقيقة
  workflow_dispatch: # يتيح لك تشغيل السكربت يدوياً بأي وقت للتجربة

jobs:
  run-bot:
    runs-on: ubuntu-latest

    steps:
    - name: Checkout repository
      uses: actions/checkout@v4

    - name: Set up Python
      uses: actions/setup-python@v5
      with:
        python-python: '3.10'

    - name: Install dependencies
      run: |
        pip install telethon feedparser

    - name: Run Watcher Bot
      env:
        API_ID: ${{ secrets.API_ID }}
        API_HASH: ${{ secrets.API_HASH }}
      run: |
        python watcher.py

    - name: Commit and Push History Changes
      run: |
        git config --global user.name "GitHub Actions"
        git config --global user.email "actions@github.com"
        git add history.txt
        git diff-index --quiet HEAD || git commit -m "Update download history [skip ci]"
        git push
